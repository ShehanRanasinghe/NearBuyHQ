<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".Order_List">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="@drawable/bg_icon_circle_white"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Orders"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🔔"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_circle_white" />
            </LinearLayout>

            <!-- Summary Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/tv_total_orders"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="12" android:textColor="#1B2D4F"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total" android:textColor="#9AA0AC" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/tv_pending_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5" android:textColor="#F5A623"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pending" android:textColor="#9AA0AC" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/tv_delivered_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="7" android:textColor="#27AE60"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Delivered" android:textColor="#9AA0AC" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- FILTER TABS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="#FFFFFF"
            android:elevation="2dp">
            <LinearLayout
                android:id="@+id/filter_tabs"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">
                <TextView android:id="@+id/tab_all"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="All" android:textColor="#FFFFFF" android:textSize="13sp"
                    android:textStyle="bold" android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_active" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_pending"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Pending" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_processing"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Processing" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_delivered"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Delivered" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ORDERS RECYCLERVIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_orders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_order" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>