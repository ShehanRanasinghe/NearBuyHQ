<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".Order_List">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_back_arrow"
                    android:background="@drawable/bg_icon_circle_white"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/deep_blue"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Orders"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Summary Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/tv_total_orders"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#1B2D4F"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total" android:textColor="#9AA0AC" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/tv_pending_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#F5A623"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pending" android:textColor="#9AA0AC" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/tv_delivered_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#27AE60"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Delivered" android:textColor="#9AA0AC" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- FILTER TABS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="#FFFFFF"
            android:elevation="2dp">
            <LinearLayout
                android:id="@+id/filter_tabs"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">
                <TextView android:id="@+id/tab_all"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="All" android:textColor="#FFFFFF" android:textSize="13sp"
                    android:textStyle="bold" android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_active" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_pending"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Pending" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_processing"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Processing" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_delivered"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Delivered" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tab_cancelled"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Cancelled" android:textColor="#9AA0AC" android:textSize="13sp"
                    android:gravity="center" android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- SEARCH BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingBottom="10dp"
            android:paddingTop="6dp">
            <EditText
                android:id="@+id/etSearchOrders"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:hint="Search orders by ID or customer…"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:background="@drawable/bg_search_bar"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />
        </LinearLayout>

        <!-- ORDERS RECYCLERVIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_orders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_order" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_dark" />

        <LinearLayout
            android:id="@+id/bottomNavBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:gravity="center"
            android:background="@color/bg_white"
            android:elevation="8dp"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/navDashboardIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/dashboard" />

                <TextView
                    android:id="@+id/navDashboardText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProducts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/navProductsIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/inventory" />

                <TextView
                    android:id="@+id/navProductsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/inventory"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navOrders"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/navOrdersIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/orders" />

                <TextView
                    android:id="@+id/navOrdersText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/orders"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAnalytics"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/navAnalyticsIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/analytics" />

                <TextView
                    android:id="@+id/navAnalyticsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/navProfileIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/profile" />

                <TextView
                    android:id="@+id/navProfileText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>