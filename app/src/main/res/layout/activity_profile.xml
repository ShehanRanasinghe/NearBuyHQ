<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/profile_bg"
    tools:context=".ProfilePage">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/profile_teal_header"
        android:paddingTop="44dp"
        android:paddingBottom="30dp"
        android:gravity="center_horizontal">

        <!-- Top row: back button + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="22dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/my_profile"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="40dp" />

        </LinearLayout>

        <!-- Circular profile picture -->
        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/profile_teal_accent">

            <ImageView
                android:id="@+id/imgProfilePicture"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_account_circle"
                android:scaleType="centerCrop"
                app:tint="@color/profile_teal_header"
                android:contentDescription="@string/profile_picture" />

        </androidx.cardview.widget.CardView>

        <!-- Owner Name -->
        <TextView
            android:id="@+id/tvOwnerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SK Groceries"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp" />

        <!-- Shop Name -->
        <TextView
            android:id="@+id/tvProfileShopName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Best In Quality Groceries"
            android:textColor="@color/profile_teal_accent"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />



    </LinearLayout>

    <!-- ===== SCROLLABLE BODY ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="22dp"
            android:paddingBottom="28dp">

            <!-- ══════════════════════════════════════ -->
            <!--   SECTION 1: ACCOUNT INFORMATION       -->
            <!-- ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/account_information"
                android:textColor="@color/text_dark_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- INFO CARD: email · phone · shop name · location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_info_card"
                android:elevation="2dp"
                android:layout_marginBottom="20dp">

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_teal"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="@color/profile_teal_accent"
                        android:contentDescription="@string/email" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/email"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="skgroceries@gmail.com"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp" android:background="@color/divider_dark" />

                <!-- Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_teal"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="@color/profile_teal_accent"
                        android:contentDescription="@string/phone" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/phone"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sample_phone"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp" android:background="@color/divider_dark" />

                <!-- Shop Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_orange"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/profile_orange"
                        android:contentDescription="@string/shop_name_label" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shop_name_label"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvShopNameDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SK Grocery Store"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp" android:background="@color/divider_dark" />

                <!-- Store Location (NEW) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_orange"
                        android:src="@android:drawable/ic_menu_mapmode"
                        app:tint="@color/profile_orange"
                        android:contentDescription="@string/store_location_label" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/store_location_label"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvShopLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sample_store_location"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!--   SECTION 2: SHOP DETAILS              -->
            <!-- ══════════════════════════════════════ -->

            <!-- Section header with Edit button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/shop_details_label"
                    android:textColor="@color/text_dark_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <LinearLayout
                    android:id="@+id/btnEditShopDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_branch_edit_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/profile_teal_accent"
                        android:contentDescription="@string/edit_shop_details"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edit_shop_details"
                        android:textColor="@color/profile_teal_accent"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- SHOP DETAILS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_info_card"
                android:elevation="2dp"
                android:layout_marginBottom="20dp">

                <!-- Store Category -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_teal"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="@color/profile_teal_accent"
                        android:contentDescription="@string/store_category_label" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/store_category_label"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvStoreCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sample_store_category"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp" android:background="@color/divider_dark" />

                <!-- Opening Hours -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_teal"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/profile_teal_accent"
                        android:contentDescription="@string/opening_hours_label" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/opening_hours_label"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvOpeningHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sample_opening_hours"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp" android:background="@color/divider_dark" />

                <!-- Website / Social -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="11dp"
                        android:background="@drawable/bg_profile_icon_orange"
                        android:src="@android:drawable/ic_menu_share"
                        app:tint="@color/profile_orange"
                        android:contentDescription="@string/website_label" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/website_label"
                            android:textColor="@color/text_dark_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvWebsite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sample_website"
                            android:textColor="@color/profile_teal_accent"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>


            <!-- ══════════════════════════════════════ -->
            <!--   SECTION 4: STATS BANNER              -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_profile_info_card"
                android:elevation="2dp"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_total_products"
                        android:textColor="@color/profile_orange"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_products"
                        android:textColor="@color/text_dark_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="44dp"
                    android:background="@color/divider_dark" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_todays_orders"
                        android:textColor="@color/profile_teal_accent"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/todays_orders"
                        android:textColor="@color/text_dark_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="44dp"
                    android:background="@color/divider_dark" />


            </LinearLayout>

            <!-- ── EDIT PROFILE BUTTON ── -->
            <LinearLayout
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_edit_profile_btn"
                android:elevation="3dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/white"
                    android:contentDescription="@string/edit_profile"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/edit_profile"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />
            </LinearLayout>

            <!-- ── LOGOUT BUTTON ── -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_profile_logout_btn"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="@color/coral_primary"
                    android:contentDescription="@string/logout"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logout"
                    android:textColor="@color/coral_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>



</LinearLayout>
