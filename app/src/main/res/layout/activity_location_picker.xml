<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_white">

    <!-- ── TOP BAR (matches project theme) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_topbar_curved"
        android:paddingTop="42dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="14dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_back_arrow"
            android:background="@drawable/bg_icon_circle_white"
            android:contentDescription="@string/back"
            app:tint="@color/deep_blue" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/location_picker_title"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="36dp" />

    </LinearLayout>

    <!-- ── MAP AREA with floating search bar ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Map container: SupportMapFragment is added programmatically
             (with a short delay) so setContentView() stays lightweight and
             the activity enter-transition completes before the heavy Maps
             native library load begins. This prevents the ProfilePage ANR. -->
        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Loading overlay – visible while the map fragment initialises.
             Hidden in onMapReady(). -->
        <LinearLayout
            android:id="@+id/mapLoadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/bg_white">

            <ProgressBar
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminate="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading map…"
                android:textColor="@color/text_dark_secondary"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Search bar + dropdown float on top of the map -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="top"
            android:layout_margin="12dp">

            <!-- Search row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:elevation="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/profile_teal_accent"
                    android:contentDescription="@string/search"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etSearchLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/search_location_hint"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark_primary"
                    android:textColorHint="@color/text_dark_hint"
                    android:background="@null"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:inputType="textCapSentences" />

            </LinearLayout>

            <!-- Autocomplete suggestions dropdown -->
            <ListView
                android:id="@+id/lvLocationSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_white"
                android:elevation="8dp"
                android:visibility="gone"
                android:divider="@color/divider_dark"
                android:dividerHeight="1dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── SELECTED COORDINATES BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvSelectedAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/location_tap_hint"
            android:textColor="@color/text_dark_secondary"
            android:textSize="13sp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/tvCoordinates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/profile_teal_accent"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── CONFIRM BUTTON ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_white"
        android:padding="14dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/btnConfirmLocation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_coral"
            android:elevation="3dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mapmode"
                app:tint="@color/white"
                android:contentDescription="@string/confirm_location"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_location"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

