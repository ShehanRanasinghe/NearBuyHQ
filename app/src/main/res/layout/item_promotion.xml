<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_order_card"
    android:elevation="3dp"
    android:padding="16dp">

    <!-- ── Top row: emoji icon  +  title / type  +  discount badge ──────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <!-- Seasonal emoji circle -->
        <TextView
            android:id="@+id/tvPromoEmoji"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="🏷️"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_promo_card"
            android:layout_marginEnd="12dp" />

        <!-- Title + Type -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPromoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_dark_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPromoType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_dark_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Discount % badge -->
        <TextView
            android:id="@+id/tvPromoDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_active"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp" />
    </LinearLayout>

    <!-- ── Divider ───────────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_dark"
        android:layout_marginBottom="10dp" />

    <!-- ── Product + Date range ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Product icon + name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦 "
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvPromoProduct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_dark_primary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvPromoStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_promo_badge_active" />
    </LinearLayout>

    <!-- ── Date range row ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗓 "
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPromoDateRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_dark_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ── Divider ───────────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_dark"
        android:layout_marginBottom="10dp" />

    <!-- ── Price row  +  action buttons ────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Original (strike-through) + Discounted -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPromoOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_dark_hint"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvPromoDiscountedPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/coral_primary"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Edit button -->
        <ImageButton
            android:id="@+id/btnPromoEdit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_edit"
            app:tint="@color/deep_blue"
            android:background="@drawable/bg_icon_circle_blue"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Edit promotion" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btnPromoDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/stat_red"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"
            android:contentDescription="Delete promotion" />
    </LinearLayout>
</LinearLayout>
