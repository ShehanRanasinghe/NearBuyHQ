<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_recent_item"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:elevation="2dp">

    <TextView
        android:id="@+id/dealTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deal Title"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark_primary" />

    <TextView
        android:id="@+id/dealShop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shop Name"
        android:textSize="14sp"
        android:textColor="@color/text_dark_secondary"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/dealDiscount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="50% OFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/coral_primary" />

        <TextView
            android:id="@+id/dealValidity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valid till"
            android:textSize="12sp"
            android:textColor="@color/text_dark_secondary" />

    </LinearLayout>

</LinearLayout>

