<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light_grey"
    tools:context=".DealDetails">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_recent_item"
            android:padding="20dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/dealTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deal Title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/deep_blue" />

            <TextView
                android:id="@+id/dealShop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shop: Fresh Mart"
                android:textSize="16sp"
                android:textColor="@color/text_dark_secondary"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/dealDiscount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discount: 50%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/coral_primary"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/dealValidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Valid till: Mar 31, 2026"
                android:textSize="16sp"
                android:textColor="@color/text_dark_secondary"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Edit"
                android:textColor="@color/white"
                android:background="@drawable/btn_coral"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Delete"
                android:textColor="@color/white"
                android:backgroundTint="@color/error_red"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back"
            android:textColor="@color/white"
            android:backgroundTint="@color/text_dark_secondary"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</ScrollView>

