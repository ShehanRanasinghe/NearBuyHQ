<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/navy_dark"
    tools:context=".OTPVerification">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo Section -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="180dp"
            android:layout_height="120dp"
            android:src="@drawable/nearbuy_logo"
            android:contentDescription="@string/logo_desc"
            android:layout_marginTop="60dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify OTP"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/coral_primary"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter the 6-digit code sent to your email"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- OTP Input Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="40dp">

            <EditText
                android:id="@+id/otp1"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_dark_primary"
                android:layout_margin="4dp" />

            <EditText
                android:id="@+id/otp2"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_dark_primary"
                android:layout_margin="4dp" />

            <EditText
                android:id="@+id/otp3"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_dark_primary"
                android:layout_margin="4dp" />

            <EditText
                android:id="@+id/otp4"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_dark_primary"
                android:layout_margin="4dp" />

            <EditText
                android:id="@+id/otp5"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_dark_primary"
                android:layout_margin="4dp" />

            <EditText
                android:id="@+id/otp6"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_dark_primary"
                android:layout_margin="4dp" />

        </LinearLayout>

        <!-- Verify Button -->
        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Verify OTP"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/btn_coral"
            android:layout_marginTop="40dp"
            android:elevation="4dp" />

        <!-- Resend OTP Link -->
        <TextView
            android:id="@+id/btnResendOTP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resend OTP"
            android:textColor="@color/coral_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>

