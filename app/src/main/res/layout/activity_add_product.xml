<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".Add_Product">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_header"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@drawable/bg_icon_circle_white"
                android:padding="8dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Add Product"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_order_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:id="@+id/layout_image_upload"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_image_upload"
                        android:gravity="center"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload"
                            android:textColor="#9AA0AC"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to upload product image"
                        android:textColor="#9AA0AC"
                        android:textSize="11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_order_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRODUCT INFO"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="14dp">

                        <EditText
                            android:id="@+id/et_product_name"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="e.g. Fresh Broccoli"
                            android:hintTextColor="#9AA0AC"
                            android:textColor="#1B2D4F"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="text" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Description"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:layout_marginBottom="14dp">

                        <EditText
                            android:id="@+id/et_product_description"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Describe your product..."
                            android:hintTextColor="#9AA0AC"
                            android:textColor="#1B2D4F"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="textMultiLine"
                            android:gravity="top" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/btn_cat_vegetables"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🥦 Veg"
                            android:gravity="center"
                            android:textColor="#27AE60"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_delivered"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btn_cat_meats"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🥩 Meat"
                            android:gravity="center"
                            android:textColor="#E03B2F"
                            android:textSize="11sp"
                            android:background="@drawable/bg_cat_inactive"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btn_cat_beverages"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🧃 Bev"
                            android:gravity="center"
                            android:textColor="#2980B9"
                            android:textSize="11sp"
                            android:background="@drawable/bg_cat_inactive"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btn_cat_snacks"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🍿 Snack"
                            android:gravity="center"
                            android:textColor="#F5A623"
                            android:textSize="11sp"
                            android:background="@drawable/bg_cat_inactive" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_order_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRICING and STOCK"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price"
                                android:textColor="#1B2D4F"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_input_field"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$"
                                    android:textColor="#E03B2F"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:layout_marginEnd="4dp" />

                                <EditText
                                    android:id="@+id/et_price"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:hint="0.00"
                                    android:hintTextColor="#9AA0AC"
                                    android:textColor="#1B2D4F"
                                    android:textSize="13sp"
                                    android:background="@null"
                                    android:inputType="numberDecimal" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Unit"
                                android:textColor="#1B2D4F"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_input_field"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp">

                                <EditText
                                    android:id="@+id/et_unit"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:hint="kg / pack"
                                    android:hintTextColor="#9AA0AC"
                                    android:textColor="#1B2D4F"
                                    android:textSize="13sp"
                                    android:background="@null"
                                    android:inputType="text" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock Quantity"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦"
                            android:textSize="16sp"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/et_stock"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Enter stock quantity"
                            android:hintTextColor="#9AA0AC"
                            android:textColor="#1B2D4F"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="number" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:elevation="16dp">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="#E03B2F"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_cancel_btn"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="Save Product"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_tab_active" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
