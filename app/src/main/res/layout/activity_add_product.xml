<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".products.Add_Product">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- TOP HEADER BAR -->
        <LinearLayout
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_topbar_curved"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="20dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@drawable/bg_icon_circle_white"
                android:padding="8dp"
                android:layout_marginEnd="12dp" />

            <!-- App Logo & Name -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgAppLogo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/nearbuy_logo"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/logo_desc" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.03"
                    android:text="Add New Product"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>



        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_order_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:id="@+id/layout_image_upload"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_image_upload"
                        android:gravity="center"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload"
                            android:textColor="#9AA0AC"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to upload product image"
                        android:textColor="#9AA0AC"
                        android:textSize="11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_order_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRODUCT INFO"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="14dp">

                        <EditText
                            android:id="@+id/et_product_name"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="e.g. Fresh Broccoli"
                            android:textColorHint="#9AA0AC"
                            android:textColor="#1B2D4F"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="text" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Description"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:layout_marginBottom="14dp">

                        <EditText
                            android:id="@+id/et_product_description"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Describe your product..."
                            android:textColorHint="#9AA0AC"
                            android:textColor="#1B2D4F"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="textMultiLine"
                            android:gravity="top" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/btn_cat_vegetables"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🥦 Veg"
                            android:gravity="center"
                            android:textColor="#27AE60"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_delivered"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btn_cat_meats"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🥩 Meat"
                            android:gravity="center"
                            android:textColor="#E03B2F"
                            android:textSize="11sp"
                            android:background="@drawable/bg_cat_inactive"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btn_cat_beverages"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🧃 Bev"
                            android:gravity="center"
                            android:textColor="#2980B9"
                            android:textSize="11sp"
                            android:background="@drawable/bg_cat_inactive"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btn_cat_snacks"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:text="🍿 Snack"
                            android:gravity="center"
                            android:textColor="#F5A623"
                            android:textSize="11sp"
                            android:background="@drawable/bg_cat_inactive" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_order_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRICING and STOCK"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price"
                                android:textColor="#1B2D4F"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_input_field"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Rs."
                                    android:textColor="#E03B2F"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:layout_marginEnd="4dp" />

                                <EditText
                                    android:id="@+id/et_price"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:hint="0.00"
                                    android:textColorHint="#9AA0AC"
                                    android:textColor="#1B2D4F"
                                    android:textSize="13sp"
                                    android:background="@null"
                                    android:inputType="numberDecimal" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Unit"
                                android:textColor="#1B2D4F"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_input_field"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp">

                                <EditText
                                    android:id="@+id/et_unit"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:hint="kg / pack"
                                    android:textColorHint="#9AA0AC"
                                    android:textColor="#1B2D4F"
                                    android:textSize="13sp"
                                    android:background="@null"
                                    android:inputType="text" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock Quantity"
                        android:textColor="#1B2D4F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦"
                            android:textSize="16sp"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/et_stock"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Enter stock quantity"
                            android:textColorHint="#9AA0AC"
                            android:textColor="#1B2D4F"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="number" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:elevation="16dp">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="#E03B2F"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_cancel_btn"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="Save Product"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_tab_active" />

        </LinearLayout>

        <!-- ── Bottom Navigation Bar ──────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottomNavBar"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@color/white"
            android:elevation="8dp"
            android:orientation="horizontal">

            <!-- Dashboard -->
            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/navDashboardIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/dashboard" />
                <TextView
                    android:id="@+id/navDashboardText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Inventory -->
            <LinearLayout
                android:id="@+id/navProducts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/navProductsIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/inventory" />
                <TextView
                    android:id="@+id/navProductsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/inventory"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Orders -->
            <LinearLayout
                android:id="@+id/navOrders"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/navOrdersIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/orders" />
                <TextView
                    android:id="@+id/navOrdersText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/orders"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Analytics -->
            <LinearLayout
                android:id="@+id/navAnalytics"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/navAnalyticsIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/analytics" />
                <TextView
                    android:id="@+id/navAnalyticsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/navProfileIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="@color/nav_inactive"
                    android:contentDescription="@string/profile" />
                <TextView
                    android:id="@+id/navProfileText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile"
                    android:textColor="@color/nav_inactive"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
