<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EBF3FF"
    tools:context=".discounts.AddDeal">

    <!-- TOP HEADER BAR -->
    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_topbar_curved"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="20dp">

        <!-- App Logo & Name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgAppLogo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/nearbuy_logo"
                android:scaleType="centerCrop"
                android:contentDescription="@string/logo_desc" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create New Deal"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />



            </LinearLayout>
        </LinearLayout>

        

    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="0dp">

            <!-- DEAL INFO CARD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:letterSpacing="0.1"
                android:text="DEAL INFO"
                android:textColor="@color/coral_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_order_card"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="12dp"
                android:textColor="@color/coral_primary">



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deal Title"
                    android:textColor="#1B2D4F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/dealTitle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="e.g. Summer Flash Sale"
                        android:textColorHint="#9AA0AC"
                        android:textColor="#1B2D4F"
                        android:textSize="13sp"
                        android:background="@null"
                        android:inputType="text" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="#1B2D4F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:layout_marginBottom="4dp">

                    <EditText
                        android:id="@+id/dealDescription"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Describe your deal offer..."
                        android:textColorHint="#9AA0AC"
                        android:textColor="#1B2D4F"
                        android:textSize="13sp"
                        android:background="@null"
                        android:inputType="textMultiLine"
                        android:gravity="top" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:letterSpacing="0.1"
                android:text="DEAL SETTINGS"
                android:textColor="@color/coral_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- DEAL SETTINGS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_order_card"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="0dp">



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shop"
                    android:textColor="#1B2D4F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/shopSelection"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="14dp" />

                <!-- Discount & Validity Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discount"
                            android:textColor="#1B2D4F"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="%"
                                android:textColor="@color/coral_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="4dp" />

                            <EditText
                                android:id="@+id/dealDiscount"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="50"
                                android:textColorHint="#9AA0AC"
                                android:textColor="#1B2D4F"
                                android:textSize="13sp"
                                android:background="@null"
                                android:inputType="numberDecimal" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Valid Until"
                            android:textColor="#1B2D4F"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp">

                            <EditText
                                android:id="@+id/dealValidity"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="DD/MM/YYYY"
                                android:textColorHint="#9AA0AC"
                                android:textColor="#1B2D4F"
                                android:textSize="13sp"
                                android:background="@null"
                                android:inputType="date" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM ACTION BAR -->

    <!--  BOTTOM NAVIGATION BAR  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_order_card"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_cancel_btn"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="#E03B2F"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSubmit"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:background="@drawable/btn_coral"
            android:gravity="center"
            android:text="Create Deal"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_dark" />
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="center"
        android:background="@color/bg_white"
        android:elevation="8dp"
        android:paddingHorizontal="8dp">
        <!-- Dashboard -->
        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/navDashboardIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@color/nav_inactive"
                android:contentDescription="@string/dashboard" />
            <TextView
                android:id="@+id/navDashboardText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <!-- Inventory -->
        <LinearLayout
            android:id="@+id/navProducts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/navProductsIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/nav_inactive"
                android:contentDescription="@string/inventory" />
            <TextView
                android:id="@+id/navProductsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inventory"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <!-- Orders -->
        <LinearLayout
            android:id="@+id/navOrders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/navOrdersIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/nav_inactive"
                android:contentDescription="@string/orders" />
            <TextView
                android:id="@+id/navOrdersText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <!-- Analytics -->
        <LinearLayout
            android:id="@+id/navAnalytics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/navAnalyticsIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="@color/nav_inactive"
                android:contentDescription="@string/analytics" />
            <TextView
                android:id="@+id/navAnalyticsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/analytics"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/navProfileIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/nav_inactive"
                android:contentDescription="@string/profile" />
            <TextView
                android:id="@+id/navProfileText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>