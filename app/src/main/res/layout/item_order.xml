<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_order_card"
    android:elevation="4dp"
    android:padding="16dp">

    <!-- Order ID + Status -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="#" android:textColor="#E03B2F" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_order_id"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#1B2D4F"
                android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:id="@+id/tv_order_status"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textColor="#FFFFFF" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="12dp" android:paddingVertical="4dp"
            android:background="@drawable/bg_status_badge" />
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" android:layout_marginBottom="10dp" />

    <!-- Customer Name -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_blue"
            android:gravity="center" android:layout_marginEnd="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="14sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Customer" android:textColor="#9AA0AC" android:textSize="10sp" />
            <TextView android:id="@+id/tv_customer_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#1B2D4F"
                android:textSize="13sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Total + Date -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ORDER TOTAL" android:textColor="#9AA0AC" android:textSize="9sp" />
            <TextView android:id="@+id/tv_order_total"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#E03B2F"
                android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DATE" android:textColor="#9AA0AC" android:textSize="9sp" />
            <TextView android:id="@+id/tv_order_date"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#1B2D4F" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>