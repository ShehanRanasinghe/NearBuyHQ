<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light_grey">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back_arrow"
                android:layout_marginEnd="12dp"
                android:padding="4dp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Report Details"
                android:textColor="#1B2D4F"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/reportStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#F5A623"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:background="@drawable/bg_status_pending" />
        </LinearLayout>

        <!-- Info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_recent_item"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="12dp">

            <!-- Type badge -->
            <TextView
                android:id="@+id/reportType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feedback"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_status_badge"
                android:layout_marginBottom="14dp" />

            <!-- Customer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CUSTOMER"
                android:textColor="#9AA0AC"
                android:textSize="10sp"
                android:letterSpacing="0.08" />
            <TextView
                android:id="@+id/tv_customer_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#1B2D4F"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <!-- Order Reference -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORDER REFERENCE"
                android:textColor="#9AA0AC"
                android:textSize="10sp"
                android:letterSpacing="0.08" />
            <TextView
                android:id="@+id/tv_order_ref"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#1B2D4F"
                android:textSize="13sp"
                android:layout_marginBottom="14dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="14dp" />

            <!-- Report Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPORT MESSAGE"
                android:textColor="#9AA0AC"
                android:textSize="10sp"
                android:letterSpacing="0.08" />
            <TextView
                android:id="@+id/reportDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#3D4452"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Mark as Resolved button -->
        <Button
            android:id="@+id/btnResolve"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Mark as Resolved"
            android:textColor="@color/white"
            android:background="@drawable/btn_coral"
            android:layout_marginTop="8dp" />

        <!-- Back button -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Back"
            android:textColor="@color/white"
            android:backgroundTint="@color/text_dark_secondary"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
