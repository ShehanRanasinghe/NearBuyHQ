<?xml version="1.0" encoding="utf-8"?>
<!-- OTP digit input box – semi-transparent navy with coral accent border -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state – coral border highlight -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#26FFFFFF" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="#FF5A4F" />
        </shape>
    </item>

    <!-- Filled / default state -->
    <item>
        <shape>
            <solid android:color="#33FFFFFF" />
            <corners android:radius="10dp" />
            <stroke android:width="1.5dp" android:color="#4DFFFFFF" />
        </shape>
    </item>

</selector>

