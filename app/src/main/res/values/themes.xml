<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.NearBuyHQ" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/coral_red</item>
        <item name="colorPrimaryVariant">@color/coral_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/deep_blue</item>
        <item name="colorSecondaryVariant">@color/deep_blue_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background_grey</item>
        <item name="colorSurface">@color/card_white</item>
        <item name="android:statusBarColor">@color/deep_blue</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- Splash Screen – full screen, deep blue -->
    <style name="Theme.NearBuyHQ.Splash" parent="Theme.NearBuyHQ">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/deep_blue</item>
        <item name="android:navigationBarColor">@color/deep_blue_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>
</resources>