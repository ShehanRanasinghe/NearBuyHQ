<resources>
    <!-- Base application theme. -->
    <style name="Theme.NearBuyHQ" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/amber_primary</item>
        <item name="colorPrimaryVariant">@color/amber_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/amber_light</item>
        <item name="colorSecondaryVariant">@color/amber_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/dashboard_surface</item>
        <item name="android:navigationBarColor">@color/nav_bar_bg</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/dashboard_bg</item>
    </style>
</resources>