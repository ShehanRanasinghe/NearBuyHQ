<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Light theme with coral/blue accent -->
    <style name="Theme.NearBuyHQ" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color - Coral Red -->
        <item name="colorPrimary">@color/coral_primary</item>
        <item name="colorPrimaryVariant">@color/coral_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color - Deep Blue -->
        <item name="colorSecondary">@color/deep_blue</item>
        <item name="colorSecondaryVariant">@color/deep_blue_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color - Deep Blue header -->
        <item name="android:statusBarColor">@color/deep_blue</item>
        <item name="android:navigationBarColor">@color/bg_white</item>
        <!-- Window background - Light grey -->
        <item name="android:windowBackground">@color/bg_light_grey</item>
    </style>

    <!-- Splash Screen – full screen, deep blue -->
    <style name="Theme.NearBuyHQ.Splash" parent="Theme.NearBuyHQ">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/deep_blue</item>
        <item name="android:navigationBarColor">@color/deep_blue_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>
</resources>