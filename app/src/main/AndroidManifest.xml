<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- GPS permissions – needed to capture shop location after registration -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NearBuyHQ"
        tools:targetApi="31">

        <!-- Google Maps API Key (read from .env → BuildConfig → manifestPlaceholders) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".settings.LocationPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".settings.ProfilePage"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".products.Inventory"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".products.Product_Details"
            android:exported="false" />
        <activity
            android:name=".products.Products_List"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".products.Add_Product"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".dashboard.Dashboard"
            android:exported="false" />
        <activity
            android:name=".orders.Order_List"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".orders.Order_details"
            android:exported="false"
            android:screenOrientation="portrait" />
        <!-- SPLASH SCREEN – Main launcher -->
        <activity
            android:name=".app.startup.SplashScreen"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NearBuyHQ.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".app.startup.Welcome"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.Login"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.Register"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".dashboard.Analytics"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".discounts.Promotions"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".discounts.DiscountsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".discounts.AddEditPromotion"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.ForgotPassword"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.OTPVerification"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".shops.ShopsList"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".shops.ShopDetails"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".shops.AddShop"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".discounts.DealsList"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".discounts.DealDetails"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".discounts.AddDeal"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".reports.Reports"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".reports.ReportDetails"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".notifications.Notifications"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".settings.LogoutConfirmation"
            android:exported="false"
            android:screenOrientation="portrait" />
    </application>

</manifest>